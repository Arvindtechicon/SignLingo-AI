# Database configuration (Replace with your local database URL)
DATABASE_URL=postgresql://username:password@localhost:5432/your_database_name

# Security configuration (Replace with a cryptographically secure random key)
# You can generate one using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_signing_key_here

# Token expiration time (in minutes, 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
